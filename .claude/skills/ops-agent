#!/bin/bash
# ops-orchestrator CLI wrapper for Claude Code

set -e

cd "$(dirname "$(dirname "$(dirname "$0")")")" || exit 1

# Parse the command first (before Vault auth)
cmd="${1:-}"
[ -n "$cmd" ] && shift || true

# Setup Vault authentication and fetch Proxmox password (only for actual commands)
setup_vault_password() {
  if [ -z "$PROXMOX_PASSWORD" ]; then
    # Authenticate to Vault if not already authenticated
    if ! vault token lookup &>/dev/null; then
      echo "==> Authenticating to Vault (AppRole)..."
      # Use AppRole auth for headless environments (SSH, CI/CD)
      source /ct/ops-central/scripts/beast-vault-login.sh || exit 1
    fi

    # Fetch Proxmox credentials from Vault
    echo "==> Fetching Proxmox credentials from Vault..."
    export PROXMOX_PASSWORD=$(vault kv get -field=password secret/proxmox 2>/dev/null)
    export PROXMOX_HOST=$(vault kv get -field=api_host_1 secret/proxmox 2>/dev/null)
    export PROXMOX_USER=$(vault kv get -field=username secret/proxmox 2>/dev/null)
    if [ -z "$PROXMOX_PASSWORD" ]; then
      echo "ERROR: Could not fetch PROXMOX_PASSWORD from Vault (secret/proxmox)." >&2
      exit 1
    fi
  fi
}

case "$cmd" in
  list-vms)
    setup_vault_password
    .venv/bin/python -m ops_agent.coordinator /list-vms "$@"
    ;;
  list-nodes)
    setup_vault_password
    .venv/bin/python -m ops_agent.coordinator /list-nodes "$@"
    ;;
  next-vmid)
    setup_vault_password
    .venv/bin/python -m ops_agent.coordinator /next-vmid "$@"
    ;;
  provision)
    setup_vault_password
    .venv/bin/python -m ops_agent.coordinator /provision "$@"
    ;;
  build-template)
    setup_vault_password

    # Node selection (default prox2 — hosts the NFS storage, avoids cross-node copies)
    node="${1:-}"
    if [ -z "$node" ]; then
      echo "Available nodes: prox  prox1  prox2  prox3  prox4"
      read -r -p "Target node [prox2]: " node
      node="${node:-prox2}"
    fi

    # Map node name to IP
    declare -A node_ip=([prox]=10.200.99.5 [prox1]=10.200.99.7 [prox2]=10.200.99.8 [prox3]=10.200.99.4 [prox4]=10.200.99.10)
    node_host="${node_ip[$node]:-}"
    if [ -z "$node_host" ]; then
      echo "ERROR: Unknown node '$node'. Valid: prox prox1 prox2 prox3 prox4" >&2
      exit 1
    fi

    # Version selection
    version="${2:-}"
    if [ -z "$version" ]; then
      echo ""
      echo "Available Ubuntu versions:"
      echo "  24.04  — Ubuntu 24.04 LTS Noble (VMID 9000)  [recommended]"
      echo "  25.10  — Ubuntu 25.10 Questing   (VMID 9500)"
      echo "  26.04  — Ubuntu 26.04 LTS         (VMID 9200)"
      read -r -p "Ubuntu version [24.04]: " version
      version="${version:-24.04}"
    fi

    # Version → cloud image URL + VMID + template name
    case "$version" in
      24.04) img_url="https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
             vmid=9000; template_name="ubuntu-2404-golden" ;;
      25.10) img_url="https://cloud-images.ubuntu.com/questing/current/questing-server-cloudimg-amd64.img"
             vmid=9500; template_name="ubuntu-2510-golden" ;;
      26.04) img_url="https://cloud-images.ubuntu.com/resolute/current/resolute-server-cloudimg-amd64.img"
             vmid=9200; template_name="ubuntu-2604-golden" ;;
      *)     echo "ERROR: Supported versions: 24.04  25.10  26.04" >&2; exit 1 ;;
    esac

    echo ""
    echo "==> Build plan (cloud image — no ISO installer):"
    echo "    Node:     $node ($node_host)"
    echo "    Version:  Ubuntu $version"
    echo "    VMID:     $vmid"
    echo "    Template: $template_name"
    echo "    Source:   $img_url"
    echo ""
    if [[ "${YES:-}" != "1" ]]; then
      read -r -p "Proceed? [Y/n]: " confirm
      [[ "${confirm:-Y}" =~ ^[Yy] ]] || { echo "Aborted."; exit 0; }
    fi

    # Write SSH keys file for the template
    cat > /tmp/ops_template_keys.pub << 'KEYS'
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJVg90BaM7cOzLTseb21By9Js6P83jtsdARzpkMt4UrM mchasse@xnitro
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDGfsIvIbq+jJRBkh0Bisluz+LX4NRDrD2dZcQmQpGZz
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGYrV9NK/7kMb64PycxuqTWduQ1WESKJmWieuOKBzacZ mchasse@storm
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDOIbTIyU3tFeAm2g6L2/lheTc6pg3Ogiof9KuJHbETj mchasse@xeronine.com
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFvNQTfctGIgfAjNsylR+aoLb+CaDLqKAGdl7KcxaG1W mchasse@beast
KEYS

    # Copy keys to the Proxmox node and run build
    sshpass -p "${PROXMOX_PASSWORD}" scp -o StrictHostKeyChecking=no \
      /tmp/ops_template_keys.pub root@${node_host}:/tmp/ops_template_keys.pub

    sshpass -p "${PROXMOX_PASSWORD}" ssh -o StrictHostKeyChecking=no root@${node_host} \
      VMID=$vmid NAME=$template_name IMG_URL=$img_url bash << 'REMOTE'
set -e
echo "==> Removing existing VMID $VMID if present..."
pvesh set /nodes/$(hostname)/qemu/$VMID/config -template 0 2>/dev/null || true
qm stop $VMID 2>/dev/null || true
rm -f /etc/pve/qemu-server/${VMID}.conf 2>/dev/null || true
lvremove -f pve/vm-${VMID}-disk-0 2>/dev/null || true
lvremove -f pve/base-${VMID}-disk-0 2>/dev/null || true
lvremove -f pve/vm-${VMID}-cloudinit 2>/dev/null || true

echo "==> Downloading cloud image..."
wget -q --show-progress -O /tmp/${NAME}.img "$IMG_URL"

echo "==> Creating VM $VMID ($NAME)..."
qm create $VMID --name "$NAME" --memory 2048 --balloon 0 --cores 2 --cpu host \
  --net0 virtio,bridge=vmbr0 --ostype l26 --agent enabled=1 \
  --tags "template;ubuntu;golden" --description "Ubuntu cloud-image template"

echo "==> Importing disk..."
qm importdisk $VMID /tmp/${NAME}.img local-lvm --format raw

echo "==> Configuring..."
qm set $VMID \
  --scsihw virtio-scsi-pci \
  --scsi0 "local-lvm:vm-${VMID}-disk-0,cache=writeback,discard=on" \
  --boot order=scsi0 \
  --ide2 local-lvm:cloudinit \
  --serial0 socket --vga serial0 \
  --ipconfig0 ip=dhcp \
  --ciuser mchasse \
  --sshkeys /tmp/ops_template_keys.pub

echo "==> Converting to template..."
qm template $VMID
rm -f /tmp/${NAME}.img /tmp/ops_template_keys.pub

echo "==> Done: $NAME (VMID $VMID) ✓"
qm config $VMID | grep -E "^name:|^template:|^scsi0:|^ide2:"
REMOTE
    rm -f /tmp/ops_template_keys.pub
    ;;
  help|"")
    cat << 'EOF'
ops-orchestrator commands:

  list-vms          List all VMs in the cluster
  list-nodes        Show all Proxmox nodes
  next-vmid         Get the next available VMID
  provision         Provision a new VM (guided)
  build-template    Build an Ubuntu golden template on a Proxmox node

Ubuntu versions:  24.04 (LTS, VMID 9000)  25.10 (VMID 9500)  26.04 (LTS, VMID 9200)
ISO storage:      prox-iso shared NAS — uploaded once, reused by all nodes

Examples:
  ops-agent list-vms
  ops-agent provision
  ops-agent build-template                  # interactive prompts for node + version
  ops-agent build-template prox1            # prompts for version only
  ops-agent build-template prox1 24.04      # fully specified, no prompts
  ops-agent build-template prox1 26.04      # build latest LTS on prox1
EOF
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "Run 'ops-agent help' for available commands" >&2
    exit 1
    ;;
esac

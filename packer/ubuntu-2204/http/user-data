#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us

  # Network — DHCP during install only; cloud-init sets static IP at deploy time
  network:
    version: 2
    ethernets:
      ens18:
        dhcp4: true

  # Storage — single root partition, no LVM, ext4
  storage:
    layout:
      name: direct
    swap:
      size: 0

  # Initial user
  identity:
    hostname: ubuntu-template
    username: mchasse
    password: "$6$rounds=4096$salt$changeme"

  # SSH — install server and add all authorized keys
  ssh:
    install-server: true
    authorized-keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJVg90BaM7cOzLTseb21By9Js6P83jtsdARzpkMt4UrM mchasse@xnitro"
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDGfsIvIbq+jJRBkh0Bisluz+LX4NRDrD2dZcQmQpGZz"
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGYrV9NK/7kMb64PycxuqTWduQ1WESKJmWieuOKBzacZ mchasse@storm"
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDOIbTIyU3tFeAm2g6L2/lheTc6pg3Ogiof9KuJHbETj mchasse@xeronine.com"
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFvNQTfctGIgfAjNsylR+aoLb+CaDLqKAGdl7KcxaG1W mchasse@beast"
    allow-pw: false

  # Minimal packages only — everything else installed by base-config.sh after SSH
  # NO package_update/upgrade here — saves 10-15 min of install time
  packages:
    - qemu-guest-agent
    - openssh-server

  # Enable guest agent and start SSH before Packer connects
  late-commands:
    - curtin in-target --target=/target -- systemctl enable qemu-guest-agent
    - curtin in-target --target=/target -- systemctl enable ssh
